<Window x:Class="SlashBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SlashBar"
        Width="800"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Opacity="0"
        Deactivated="Window_Deactivated">

    <Border x:Name="RootBorder"
            Background="#E6121216"
            BorderBrush="#28FFFFFF"
            BorderThickness="1"
            CornerRadius="0,0,14,14"
            RenderTransformOrigin="0.5,0">
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="-20"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              ShadowDepth="8"
                              Direction="270"
                              Opacity="0.4"
                              Color="#000000"/>
        </Border.Effect>

        <StackPanel>
            <Grid Height="56" Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="⌕"
                           FontSize="18"
                           Foreground="#66FFFFFF"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0"/>

                <Grid Grid.Column="1">
                    <TextBlock x:Name="GhostText"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="15"
                               FontWeight="Medium"
                               Foreground="#55FFFFFF"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>

                    <TextBox x:Name="SearchBox"
                             FontFamily="Segoe UI Variable Text, Segoe UI"
                             FontSize="15"
                             FontWeight="Medium"
                             CaretBrush="#E8E8EC"
                             Foreground="#E8E8EC"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             VerticalContentAlignment="Center"
                             VerticalAlignment="Center"
                             SelectionBrush="#33FFFFFF"/>

                    <TextBlock Text="Rechercher..."
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="15"
                               FontWeight="Medium"
                               Foreground="#66FFFFFF"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Border Grid.Column="2"
                        Background="#14FFFFFF"
                        CornerRadius="6"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                    <TextBlock Text="esc"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#55FFFFFF"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <StackPanel x:Name="SuggestionsPanel"
                        Visibility="Collapsed"
                        Opacity="0"
                        IsHitTestVisible="False">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="SuggestionsSlide" Y="-6"/>
                </StackPanel.RenderTransform>

                <Border Height="1"
                        Background="#1FFFFFFF"
                        Margin="20,0"/>

                <ItemsControl x:Name="SuggestionsList"
                              Margin="20,10,20,14"
                              Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#E8E8EC"
                                           Text="{Binding Prefix}"/>
                                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           Foreground="#40FFFFFF"
                                           Text="  ·  "/>
                                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="#B4B4BC"
                                           Text="{Binding Name}"/>
                                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="13"
                                           Foreground="#40FFFFFF"
                                           Text="  ·  "/>
                                <TextBlock FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="12"
                                           Foreground="#66FFFFFF"
                                           VerticalAlignment="Center"
                                           Text="{Binding Description}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
