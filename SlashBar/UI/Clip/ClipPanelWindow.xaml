<Window x:Class="SlashBar.ClipPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SlashBar Clip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        ShowActivated="True">

    <!-- wrapper : ombre + slide -->
    <Border Background="Transparent"
            RenderTransformOrigin="0,0.5">
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" X="-354"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="40"
                              ShadowDepth="12"
                              Direction="270"
                              Opacity="0.28"
                              Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>

            <!-- carte Apple / Spotlight -->
            <Border x:Name="RootBorder"
                    Grid.Column="1"
                    CornerRadius="24"
                    Background="#F2F2F7"
                    BorderBrush="#1A000000"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="HeaderBar"
                            Grid.Row="0"
                            Background="#E8E8ED"
                            BorderBrush="#14000000"
                            BorderThickness="0,0,0,1"
                            CornerRadius="24,24,0,0"
                            Padding="14,12"
                            Cursor="SizeAll"
                            MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- icône clipboard (2 feuilles) -->
                            <Grid Grid.Column="0"
                                  Width="16"
                                  Height="18"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  IsHitTestVisible="False">
                                <Border Width="11"
                                        Height="14"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Bottom"
                                        CornerRadius="2"
                                        BorderBrush="#8E8E93"
                                        BorderThickness="1.6"
                                        Background="Transparent"/>
                                <Border Width="11"
                                        Height="14"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        CornerRadius="2"
                                        BorderBrush="#8E8E93"
                                        BorderThickness="1.6"
                                        Background="#E8E8ED"/>
                            </Grid>

                            <TextBlock Grid.Column="1"
                                       Text="Presse-papiers"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="15"
                                       FontWeight="Medium"
                                       Foreground="#3C3C43"
                                       VerticalAlignment="Center"
                                       Opacity="0.55"
                                       IsHitTestVisible="False"/>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <!-- feu orange : reset position -->
                                <Button x:Name="ResetButton"
                                        Click="ResetButton_Click"
                                        Width="19"
                                        Height="19"
                                        Cursor="Hand"
                                        ToolTip="Position d'origine"
                                        Margin="0,0,8,0"
                                        Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg"
                                                    Background="#FEBC2E"
                                                    CornerRadius="9.5"
                                                    Width="19"
                                                    Height="19">
                                                <Viewbox Width="8" Height="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="10" Height="10">
                                                        <Path Stroke="#985712"
                                                              StrokeThickness="2.2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Data="M 1,5 L 9,5"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#E5A927"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#CC9520"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- feu rouge : fermer -->
                                <Button Click="CloseButton_Click"
                                        Width="19"
                                        Height="19"
                                        Cursor="Hand"
                                        ToolTip="Fermer"
                                        VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bg"
                                                    Background="#FF5D5B"
                                                    CornerRadius="9.5"
                                                    Width="19"
                                                    Height="19">
                                                <Viewbox Width="7" Height="7" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="10" Height="10">
                                                        <Path Stroke="#9B1C16"
                                                              StrokeThickness="2.4"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Data="M 1,1 L 9,9 M 9,1 L 1,9"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#E0443E"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#C93A35"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#F2F2F7"
                            CornerRadius="0,0,24,24">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Padding="12,10,12,14">
                            <ItemsControl x:Name="HistoryList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12,10"
                                                Cursor="Hand"
                                                Background="#FFFFFF"
                                                BorderBrush="#14000000"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                MouseLeftButtonUp="HistoryItem_Click"
                                                Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8F8FA"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Text}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="40"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,10,0"
                                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                                           FontSize="13"
                                                           Foreground="#3C3C43"/>

                                                <!-- corbeille -->
                                                <Button Grid.Column="1"
                                                        Click="DeleteHistoryItem_Click"
                                                        Tag="{Binding}"
                                                        Width="28"
                                                        Height="28"
                                                        Cursor="Hand"
                                                        ToolTip="Supprimer"
                                                        VerticalAlignment="Center">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bg"
                                                                    Background="Transparent"
                                                                    CornerRadius="8"
                                                                    Width="28"
                                                                    Height="28">
                                                                <Viewbox Width="13" Height="16"
                                                                         Stretch="Uniform"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center">
                                                                    <Canvas Width="24" Height="28">
                                                                        <Path x:Name="Icon"
                                                                              Fill="#8E8E93"
                                                                              Data="M9,2 L15,2 L16.5,5 L21,5 L21,7.5 L3,7.5 L3,5 L7.5,5 Z M5,10 L7.2,10 L7.2,22 L5,22 Z M10.9,10 L13.1,10 L13.1,22 L10.9,22 Z M16.8,10 L19,10 L19,22 L16.8,22 Z M4,26 L20,26 C21.1,26 22,25.1 22,24 L22,10 L2,10 L2,24 C2,25.1 2.9,26 4,26 Z"/>
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bg" Property="Background" Value="#1AFF3B30"/>
                                                                    <Setter TargetName="Icon" Property="Fill" Value="#FF3B30"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="Bg" Property="Background" Value="#33FF3B30"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- onglet flèche -->
            <Button x:Name="DockButton"
                    Grid.Column="2"
                    Click="DockButton_Click"
                    Width="34"
                    Height="100"
                    Margin="-2,0,0,0"
                    Cursor="Hand"
                    VerticalAlignment="Center"
                    ToolTip="Replier / Déplier">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TabBg"
                                Background="#E8E8ED"
                                BorderBrush="#1A000000"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,14,14,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="#DEDEE3"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TabBg" Property="Background" Value="#D1D1D6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Path x:Name="Chevron"
                      Stroke="#8E8E93"
                      StrokeThickness="2.2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Width="10"
                      Height="14"
                      Stretch="Uniform"
                      Data="M 6,0 L 1,6 L 6,12"/>
            </Button>
        </Grid>
    </Border>
</Window>
